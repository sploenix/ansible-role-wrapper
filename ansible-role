#!/usr/bin/env python3

import difflib
import os
import pty
import sys
import tempfile
from argparse import ArgumentParser

from sh import ansible_galaxy

# cache for ansible_galaxy collection list output
_collection_list_cache = None


def get_cached_collection_list():
    """Get cached output from ansible_galaxy collection list."""
    global _collection_list_cache
    if _collection_list_cache is None:
        _collection_list_cache = ansible_galaxy("collection", "list")
    return _collection_list_cache


parser = ArgumentParser(description="Run ansible role in collection")
parser.add_argument("fqcn", help="Fully qualified collection name (namespace.collection.role)")
parser.add_argument("--debug", default=False, action="store_true")
parser.add_argument(
    "--skip-facts",
    default=False,
    action="store_true",
    help="Set gather_facts: false in generated playbook",
)

parser.add_argument("--tasks-from", default=None)

ARGS, ansible_args = parser.parse_known_args()


class Playbook:
    tmpfile = None
    name = None

    def __init__(self, fqcn: str, skip_facts: bool = False, tasks_from: str | None = None):
        self.tmpfile = tempfile.NamedTemporaryFile(suffix=".yml", prefix="ansible-role-playbook")
        self.name = self.tmpfile.name
        fhandle = open(self.name, "w")
        fhandle.write("---\n")
        fhandle.write(f"- name: temporary playbook for role {fqcn} generated by ansible-role wrapper\n")
        fhandle.write("  hosts: all\n")

        if skip_facts:
            fhandle.write("  gather_facts: false\n")

        if tasks_from:
            fhandle.write("  tasks:\n")
            fhandle.write("    - ansible.builtin.import_role:\n")
            fhandle.write(f"        name: {fqcn}\n")
            fhandle.write(f"        tasks_from: {tasks_from}\n")
        else:
            fhandle.write("  roles:\n")
            fhandle.write(f"    - {fqcn}\n")
        fhandle.close()

    def run(self, playbook_args):
        if ARGS.debug:
            args = " ".join(playbook_args)
            print(f'Run "ansible-playbook {self.name} {args}"')

        # run ansible-playbook in pty (to get colours and live output)
        def read(fd):
            data = os.read(fd, 1024)
            return data

        cmd = ["ansible-playbook", self.name] + playbook_args
        pty.spawn(cmd, read)


def get_collection_dir(namespace_collection):
    all_collections_output = get_cached_collection_list()

    # parse output to find the collection
    lines = all_collections_output.split("\n")
    current_base_path = None

    for line in lines:
        # lines starting with # / are base paths
        if line.strip().startswith("# /"):
            current_base_path = line.strip().replace("# ", "")
        # lines with collection names (contain dots and are not separators)
        elif current_base_path and "." in line and not line.startswith("-"):
            collection_name = line.strip().split()[0]
            if collection_name == namespace_collection:
                return f"{current_base_path}/{namespace_collection.replace('.', '/')}"

    # collection not found
    print(f"Collection {namespace_collection} not found")
    exit(1)


def fuzzy_check(role_name):
    # get list of all available roles from all collections for fuzzy matching
    available_roles = []

    # get all collections (cached)
    all_collections_output = get_cached_collection_list()
    # parse output to get collection paths and names
    lines = all_collections_output.split("\n")
    current_base_path = None

    for line in lines:
        # lines starting with # / are base paths
        if line.strip().startswith("# /"):
            current_base_path = line.strip().replace("# ", "")
        # lines with collection names (contain dots and are not separators)
        elif current_base_path and "." in line and not line.startswith("-"):
            collection_name = line.strip().split()[0]
            # build full path: base_path/namespace/collection
            collection_path = f"{current_base_path}/{collection_name.replace('.', '/')}"
            roles_dir = f"{collection_path}/roles"
            if os.path.isdir(roles_dir):
                for role in os.listdir(roles_dir):
                    role_path = os.path.join(roles_dir, role)
                    if os.path.isdir(role_path):
                        # store as tuple: (role_name, full_fqcn)
                        available_roles.append((role, f"{collection_name}.{role}"))

    # extract just role names for fuzzy matching
    role_names = [r[0] for r in available_roles]

    # find close matches using difflib
    fuzzy_suggestions = difflib.get_close_matches(role_name, role_names, n=3, cutoff=0.6)

    # also check for roles that start with the search term
    # or roles where the search term is a prefix
    prefix_suggestions = [r[0] for r in available_roles if r[0].startswith(role_name) or role_name.startswith(r[0])]

    # merge and deduplicate suggestions
    all_suggestions = list(set(fuzzy_suggestions + prefix_suggestions))

    if not all_suggestions:
        return

    # build list of full FQCNs for suggestions
    suggested_fqcns = []
    for suggestion in all_suggestions[:3]:
        # find the full FQCN for this suggestion
        for role_name_tuple, full_fqcn in available_roles:
            if role_name_tuple == suggestion:
                suggested_fqcns.append(full_fqcn)
                break

    # deduplicate suggestions
    suggested_fqcns = list(dict.fromkeys(suggested_fqcns))
    suggested_roles = " or ".join(suggested_fqcns)
    print(f"Do you mean: {suggested_roles}?")


def parse_ansible_fqcn():
    # check fqcn syntax
    fqcn = ARGS.fqcn
    if fqcn.count(".") != 2:
        print("Invalid ansible role syntax - exit!")
        print(f"{fqcn} != namespace.collection.role")
        exit(1)

    # split namespace.collection from fqcn
    namespace_collection = ".".join(fqcn.split(".")[0:2])
    role_name = fqcn.split(".")[2]

    # get local directory for collection
    collection_dir = get_collection_dir(namespace_collection)

    if ARGS.debug:
        print(f"Found collection: {collection_dir}")

    # check if collection contains role
    if not os.path.isdir(f"{collection_dir}/roles/{role_name}"):
        print(f"Collection {namespace_collection} does not contain role {role_name}.")
        fuzzy_check(role_name)
        exit(1)

    if ARGS.debug:
        print(f"Found role {collection_dir}/roles/{role_name}")


def main():
    parse_ansible_fqcn()

    # generate temporary playbook and run it
    Playbook(ARGS.fqcn, tasks_from=ARGS.tasks_from, skip_facts=ARGS.skip_facts).run(ansible_args)

    return 0


if __name__ == "__main__":
    sys.exit(main())
